  "11": {
    "diagnostic_principal": "Tachycardie ventriculaire",
    "category": "Troubles du Rythme",
    "commentaire_correcteur": "QRS large, monomorphe, régulier, à plus de 100 bpm, sans onde P visible : c'est une tachycardie ventriculaire monomorphe régulière. C'est un diagnostic urgent qui nécessite une prise en charge rapide. Pas de dissociation atrioventriculaire visible, il ne fallait pas manquer la capture du dernier complexe ventriculaire",
    "annotations": [
      {
        "concept": "Tachycardie ventriculaire",
        "category": "DIAGNOSTIC_URGENT",
        "type": "expert",
        "coefficient": 1.0,
        "annotation_role": "🎯 Diagnostic validant",
        "is_exclusion": false
      }
    ]
  },
